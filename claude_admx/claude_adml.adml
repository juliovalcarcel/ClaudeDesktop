<?xml version="1.0" encoding="utf-8"?>
<policyDefinitionResources xmlns:xsd="http://www.w3.org/2001/XMLSchema"
                            xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                            xmlns="http://schemas.microsoft.com/GroupPolicy/2006/07/PolicyDefinitions"
                            revision="1.0"
                            schemaVersion="1.0">

  <displayName>Claude Desktop</displayName>
  <description>Administrative Templates for Anthropic Claude Desktop enterprise configuration.</description>

  <resources>
    <stringTable>

      <!-- Supported On -->
      <string id="SUPPORTED_WIN10_AND_LATER">Windows 10 and later</string>

      <!-- Categories -->
      <string id="Claude_Category">Claude Desktop</string>
      <string id="Claude_Updates_Category">Updates</string>
      <string id="Claude_Features_Category">Features</string>

      <!-- ═══════════════════════════════════════════════
           UPDATE POLICIES
           ═══════════════════════════════════════════════ -->

      <string id="DisableAutoUpdates">Disable Auto Updates</string>
      <string id="DisableAutoUpdates_Explain">
Controls whether Claude Desktop automatically updates itself.

Set to 0 (recommended) to allow automatic updates.
Set to 1 to disable automatic updates.

Registry key: HKLM\SOFTWARE\Policies\Claude\disableAutoUpdates
      </string>

      <string id="AutoUpdaterEnforcementHours">Auto Updater Enforcement Hours</string>
      <string id="AutoUpdaterEnforcementHours_Explain">
Sets the maximum number of hours Claude Desktop will wait before force-restarting to apply a pending update.

Accepted values: 1 to 72 hours.
Default recommended value: 72.

Registry key: HKLM\SOFTWARE\Policies\Claude\autoUpdaterEnforcementHours
      </string>

      <!-- ═══════════════════════════════════════════════
           FEATURE POLICIES
           ═══════════════════════════════════════════════ -->

      <string id="SecureVmFeaturesEnabled">Enable Cowork (Secure VM Features)</string>
      <string id="SecureVmFeaturesEnabled_Explain">
Enables or disables the Cowork feature in Claude Desktop, which requires the Windows Virtual Machine Platform to be active.

Set to 1 to enable Cowork.
Set to 0 to disable Cowork.

Note: The Virtual Machine Platform Windows feature must be enabled on the device for Cowork to function.

Registry key: HKLM\SOFTWARE\Policies\Claude\secureVmFeaturesEnabled
      </string>

      <string id="IsDesktopExtensionEnabled">Enable Desktop Extensions</string>
      <string id="IsDesktopExtensionEnabled_Explain">
Controls whether desktop extensions are enabled in Claude Desktop.

Set to 1 to enable desktop extensions.
Set to 0 to disable desktop extensions.

Note: If this value is set to 0, the extension allowlist will not be populated.

Registry key: HKLM\SOFTWARE\Policies\Claude\isDesktopExtensionEnabled
      </string>

      <string id="IsDesktopExtensionDirectoryEnabled">Enable Extension Directory</string>
      <string id="IsDesktopExtensionDirectoryEnabled_Explain">
Controls whether the extension directory is accessible in Claude Desktop.

Set to 1 to enable the extension directory.
Set to 0 to disable the extension directory.

Note: If this value is set to 0, the extension allowlist will not be populated.

Registry key: HKLM\SOFTWARE\Policies\Claude\isDesktopExtensionDirectoryEnabled
      </string>

      <string id="IsLocalDevMcpEnabled">Enable Local Dev MCP Servers</string>
      <string id="IsLocalDevMcpEnabled_Explain">
Controls whether locally configured MCP (Model Context Protocol) servers are enabled in Claude Desktop.

Set to 1 to allow local MCP servers.
Set to 0 to block local MCP servers.

Registry key: HKLM\SOFTWARE\Policies\Claude\isLocalDevMcpEnabled
      </string>

      <string id="IsClaudeCodeForDesktopEnabled">Enable Claude Code for Desktop</string>
      <string id="IsClaudeCodeForDesktopEnabled_Explain">
Controls whether the Claude Code feature is accessible within Claude Desktop.

Set to 1 to enable Claude Code in the desktop app.
Set to 0 to disable Claude Code in the desktop app.

Registry key: HKLM\SOFTWARE\Policies\Claude\isClaudeCodeForDesktopEnabled
      </string>

    </stringTable>

    <presentationTable>

      <presentation id="DisableAutoUpdates">
        <decimalTextBox refId="DisableAutoUpdates_Value" defaultValue="0">Disable Auto Updates (0 = enabled, 1 = disabled):</decimalTextBox>
      </presentation>

      <presentation id="AutoUpdaterEnforcementHours">
        <decimalTextBox refId="AutoUpdaterEnforcementHours_Value" defaultValue="72">Enforcement Hours (1-72):</decimalTextBox>
      </presentation>

      <presentation id="SecureVmFeaturesEnabled">
        <decimalTextBox refId="SecureVmFeaturesEnabled_Value" defaultValue="1">Enable Cowork (0 = disabled, 1 = enabled):</decimalTextBox>
      </presentation>

      <presentation id="IsDesktopExtensionEnabled">
        <decimalTextBox refId="IsDesktopExtensionEnabled_Value" defaultValue="1">Enable Desktop Extensions (0 = disabled, 1 = enabled):</decimalTextBox>
      </presentation>

      <presentation id="IsDesktopExtensionDirectoryEnabled">
        <decimalTextBox refId="IsDesktopExtensionDirectoryEnabled_Value" defaultValue="1">Enable Extension Directory (0 = disabled, 1 = enabled):</decimalTextBox>
      </presentation>

      <presentation id="IsLocalDevMcpEnabled">
        <decimalTextBox refId="IsLocalDevMcpEnabled_Value" defaultValue="1">Enable Local Dev MCP (0 = disabled, 1 = enabled):</decimalTextBox>
      </presentation>

      <presentation id="IsClaudeCodeForDesktopEnabled">
        <decimalTextBox refId="IsClaudeCodeForDesktopEnabled_Value" defaultValue="1">Enable Claude Code for Desktop (0 = disabled, 1 = enabled):</decimalTextBox>
      </presentation>

    </presentationTable>
  </resources>
</policyDefinitionResources>
