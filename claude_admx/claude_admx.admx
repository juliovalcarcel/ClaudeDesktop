<?xml version="1.0" encoding="utf-8"?>
<policyDefinitions xmlns:xsd="http://www.w3.org/2001/XMLSchema"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xmlns="http://schemas.microsoft.com/GroupPolicy/2006/07/PolicyDefinitions"
                   revision="1.0"
                   schemaVersion="1.0">

  <policyNamespaces>
    <target prefix="claude" namespace="Anthropic.Policies.Claude" />
  </policyNamespaces>

  <resources minRequiredRevision="1.0" />

  <supportedOn>
    <definitions>
      <definition name="SUPPORTED_WIN10_AND_LATER" displayName="$(string.SUPPORTED_WIN10_AND_LATER)" />
    </definitions>
  </supportedOn>

  <categories>
    <category name="Claude" displayName="$(string.Claude_Category)" />
    <category name="Claude_Updates" displayName="$(string.Claude_Updates_Category)">
      <parentCategory ref="Claude" />
    </category>
    <category name="Claude_Features" displayName="$(string.Claude_Features_Category)">
      <parentCategory ref="Claude" />
    </category>
  </categories>

  <policies>

    <!-- ═══════════════════════════════════════════════
         UPDATE POLICIES
         ═══════════════════════════════════════════════ -->

    <policy name="DisableAutoUpdates"
            class="Machine"
            displayName="$(string.DisableAutoUpdates)"
            explainText="$(string.DisableAutoUpdates_Explain)"
            presentation="$(presentation.DisableAutoUpdates)"
            key="SOFTWARE\Policies\Claude">
      <parentCategory ref="Claude_Updates" />
      <supportedOn ref="SUPPORTED_WIN10_AND_LATER" />
      <elements>
        <decimal id="DisableAutoUpdates_Value"
                 valueName="disableAutoUpdates"
                 minValue="0"
                 maxValue="1" />
      </elements>
    </policy>

    <policy name="AutoUpdaterEnforcementHours"
            class="Machine"
            displayName="$(string.AutoUpdaterEnforcementHours)"
            explainText="$(string.AutoUpdaterEnforcementHours_Explain)"
            presentation="$(presentation.AutoUpdaterEnforcementHours)"
            key="SOFTWARE\Policies\Claude">
      <parentCategory ref="Claude_Updates" />
      <supportedOn ref="SUPPORTED_WIN10_AND_LATER" />
      <elements>
        <decimal id="AutoUpdaterEnforcementHours_Value"
                 valueName="autoUpdaterEnforcementHours"
                 minValue="1"
                 maxValue="72" />
      </elements>
    </policy>

    <!-- ═══════════════════════════════════════════════
         FEATURE POLICIES
         ═══════════════════════════════════════════════ -->

    <policy name="SecureVmFeaturesEnabled"
            class="Machine"
            displayName="$(string.SecureVmFeaturesEnabled)"
            explainText="$(string.SecureVmFeaturesEnabled_Explain)"
            presentation="$(presentation.SecureVmFeaturesEnabled)"
            key="SOFTWARE\Policies\Claude">
      <parentCategory ref="Claude_Features" />
      <supportedOn ref="SUPPORTED_WIN10_AND_LATER" />
      <elements>
        <decimal id="SecureVmFeaturesEnabled_Value"
                 valueName="secureVmFeaturesEnabled"
                 minValue="0"
                 maxValue="1" />
      </elements>
    </policy>

    <policy name="IsDesktopExtensionEnabled"
            class="Machine"
            displayName="$(string.IsDesktopExtensionEnabled)"
            explainText="$(string.IsDesktopExtensionEnabled_Explain)"
            presentation="$(presentation.IsDesktopExtensionEnabled)"
            key="SOFTWARE\Policies\Claude">
      <parentCategory ref="Claude_Features" />
      <supportedOn ref="SUPPORTED_WIN10_AND_LATER" />
      <elements>
        <decimal id="IsDesktopExtensionEnabled_Value"
                 valueName="isDesktopExtensionEnabled"
                 minValue="0"
                 maxValue="1" />
      </elements>
    </policy>

    <policy name="IsDesktopExtensionDirectoryEnabled"
            class="Machine"
            displayName="$(string.IsDesktopExtensionDirectoryEnabled)"
            explainText="$(string.IsDesktopExtensionDirectoryEnabled_Explain)"
            presentation="$(presentation.IsDesktopExtensionDirectoryEnabled)"
            key="SOFTWARE\Policies\Claude">
      <parentCategory ref="Claude_Features" />
      <supportedOn ref="SUPPORTED_WIN10_AND_LATER" />
      <elements>
        <decimal id="IsDesktopExtensionDirectoryEnabled_Value"
                 valueName="isDesktopExtensionDirectoryEnabled"
                 minValue="0"
                 maxValue="1" />
      </elements>
    </policy>

    <policy name="IsLocalDevMcpEnabled"
            class="Machine"
            displayName="$(string.IsLocalDevMcpEnabled)"
            explainText="$(string.IsLocalDevMcpEnabled_Explain)"
            presentation="$(presentation.IsLocalDevMcpEnabled)"
            key="SOFTWARE\Policies\Claude">
      <parentCategory ref="Claude_Features" />
      <supportedOn ref="SUPPORTED_WIN10_AND_LATER" />
      <elements>
        <decimal id="IsLocalDevMcpEnabled_Value"
                 valueName="isLocalDevMcpEnabled"
                 minValue="0"
                 maxValue="1" />
      </elements>
    </policy>

    <policy name="IsClaudeCodeForDesktopEnabled"
            class="Machine"
            displayName="$(string.IsClaudeCodeForDesktopEnabled)"
            explainText="$(string.IsClaudeCodeForDesktopEnabled_Explain)"
            presentation="$(presentation.IsClaudeCodeForDesktopEnabled)"
            key="SOFTWARE\Policies\Claude">
      <parentCategory ref="Claude_Features" />
      <supportedOn ref="SUPPORTED_WIN10_AND_LATER" />
      <elements>
        <decimal id="IsClaudeCodeForDesktopEnabled_Value"
                 valueName="isClaudeCodeForDesktopEnabled"
                 minValue="0"
                 maxValue="1" />
      </elements>
    </policy>

  </policies>
</policyDefinitions>
